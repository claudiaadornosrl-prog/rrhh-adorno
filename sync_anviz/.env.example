# ═══════════════════════════════════════════════════════════════════════
#  Configuración sync_anviz — Copiar a .env y completar valores
#  NO subir a git (.env está en .gitignore)
# ═══════════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://kwwiykssrpabncpqtmwi.supabase.co
# IMPORTANTE: usar service_role key (Supabase → Settings → API → service_role)
# NO usar la anon key. NUNCA expone esta key en frontend ni en git.
SUPABASE_SERVICE_KEY=eyJ...

# ── Cuentas Anviz CrossChex Cloud ────────────────────────────────────
# Region: us / eu / ap / cn (mirar URL de tu panel CrossChex)
# Si tu URL es https://us.crosschexcloud.com → region=us

# Oficina (Don Torcuato)
ANVIZ_OFICINA_KEY=7708294b5678c1ff2f24651850625893
ANVIZ_OFICINA_SECRET=28b61ff805b7105a8cd98ff424dbff41
ANVIZ_OFICINA_REGION=us

# Unicenter (Martínez)
ANVIZ_UNICENTER_KEY=
